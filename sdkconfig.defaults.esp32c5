# ─── LilyGo T-Dongle-C5 (ESP32-C5HR8) overrides ───────────────────────────────
# Loaded automatically by ESP-IDF after sdkconfig.defaults when the target is
# esp32c5 (`idf.py set-target esp32c5`). Only the deltas the on-device display +
# PSRAM need live here.
#
# Flash size stays 4 MB (from sdkconfig.defaults) on purpose: partitions.csv is
# sized to fill 4 MB so ONE table serves every target — the T-Dongle-C5's 16 MB
# just leaves the top unused. Console (USB-Serial/JTAG) is already set in the base.

# PSRAM: the ESP32-C5HR8 carries 8 MB in-package Quad-SPI PSRAM. Put the display
# framebuffer there and move WiFi/LWIP buffers off the smaller internal SRAM
# (384 KB), relieving the largest-contiguous-block pressure this firmware is
# sensitive to. IGNORE_NOTFOUND keeps a PSRAM-less board booting — the framebuffer
# then falls back to internal RAM (display.cpp handles the SPIRAM-alloc failure).
CONFIG_SPIRAM=y
CONFIG_SPIRAM_MODE_QUAD=y
CONFIG_SPIRAM_SPEED_80M=y
CONFIG_SPIRAM_USE_MALLOC=y
CONFIG_SPIRAM_MALLOC_ALWAYSINTERNAL=16384
CONFIG_SPIRAM_TRY_ALLOCATE_WIFI_LWIP=y
CONFIG_SPIRAM_IGNORE_NOTFOUND=y

# Drive the onboard 0.96" ST7735 status display (pins default to the T-Dongle-C5
# wiring in main/Kconfig.projbuild: MOSI2 / SCK6 / CS10 / DC3 / RST1 / BL0).
CONFIG_TESLA_DISPLAY_ENABLED=y

# Optimize the C5 build for SIZE (-Os). Only the C5 carries the display + PSRAM
# support, which at the default -Og push the image past the 64 KB Secure-Boot
# boundary and fill the OTA app slot (0x1f0000) with no room for the signature.
# -Os recovers ~100 KB+ of flash at no functional cost, restoring comfortable
# headroom under the slot; the other four targets keep the base optimization.
CONFIG_COMPILER_OPTIMIZATION_SIZE=y
