menu "Tesla Key Configuration"

    config TESLA_WIFI_SSID
        string "WiFi SSID"
        default ""
        help
            SSID of the WiFi network to connect to.
            Leave empty to boot into the SoftAP setup portal ("tesla-key-esp32-setup")
            on first start, where WiFi + VIN can be entered from a phone.

    config TESLA_WIFI_PASSWORD
        string "WiFi Password"
        default ""
        help
            Password for the WiFi network.

    config TESLA_VIN
        string "Tesla Vehicle VIN"
        default ""
        help
            17-character VIN of your Tesla vehicle.
            Can also be set at runtime via NVS.

    config TESLA_BLE_MAC
        string "Tesla BLE MAC address (optional)"
        default ""
        help
            BLE MAC address of the vehicle (AA:BB:CC:DD:EE:FF).
            If empty, the device scans for any Tesla BLE beacon.
            After first scan, the discovered MAC is saved to NVS.

    config TESLA_OTA_MANIFEST_URL
        string "OTA manifest URL"
        default "https://0bu.github.io/tesla-key-esp32/manifest.json"
        help
            HTTPS URL of the manifest.json published by CI. Its "version" field is
            compared against the running firmware to decide whether an update is
            available. Must be HTTPS (verified against the bundled CA roots).

    config TESLA_OTA_FIRMWARE_URL
        string "OTA firmware (app .bin) URL"
        default "https://0bu.github.io/tesla-key-esp32/tesla-key-esp32.bin"
        help
            HTTPS URL of the app image (tesla-key-esp32.bin) downloaded and flashed
            to the inactive OTA slot by esp_https_ota. Must be HTTPS.

endmenu
