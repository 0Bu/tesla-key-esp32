# Target is selected per build: `idf.py set-target <esp32|esp32s3|esp32c3|esp32c6>`
# (the four chips yoziru/tesla-ble declares support for). Intentionally NOT pinned here
# so the one source tree builds for every supported target; CI builds all of them.

# Flash. 4 MB is the smallest part across the supported targets, so it sizes the
# partition table (partitions.csv); a larger chip just leaves the top unused, so ONE
# image + table serves every board.
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"

# Console over native USB-Serial/JTAG — present on esp32s3 / esp32c3 / esp32c6. The
# classic esp32 has no such peripheral, so this symbol is absent for that target and the
# console falls back to UART0 (the board's USB-UART bridge) automatically — no per-target
# sdkconfig needed. On boards with a separate USB-UART bridge, attach to the native-USB
# port for logs (the bridge port won't carry them).
CONFIG_ESP_CONSOLE_USB_SERIAL_JTAG=y

# OTA: roll back automatically if a freshly-flashed image fails to boot/run.
# The new app must call esp_ota_mark_app_valid_cancel_rollback() once healthy
# (see main.cpp), otherwise the bootloader reverts to the previous slot.
CONFIG_BOOTLOADER_APP_ROLLBACK_ENABLE=y

# ── Signed OTA images (Secure Boot v2 signature scheme, WITHOUT hardware Secure Boot) ──
# Require a valid RSA-3072 app signature on every OTA update, so a compromised update host
# (or its GitHub Pages source) can no longer push UNSIGNED firmware — closing the supply-
# chain gap documented in docs/SECURITY.md. No eFuses are burned: this is reversible, has
# no brick risk, and the web-installer / USB-flash path keeps working (with RSA the bootloader
# does NOT verify on boot — SECURE_SIGNED_ON_BOOT_NO_SECURE_BOOT is ECDSA-only — only the
# running app verifies the next OTA image). Trust is bootstrapped from the running app's own
# signature block (trust-on-first-use): the FIRST signed image reaches a device from the
# current UNSIGNED build (which doesn't verify) or via USB; from then on every OTA image must
# be signed with the same offline key. Classic esp32 needs chip rev v3.0+ (ECO3) for the V2
# RSA scheme — enforced in sdkconfig.defaults.esp32. Full key lifecycle: docs/SECURITY.md.
CONFIG_SECURE_SIGNED_APPS_NO_SECURE_BOOT=y
CONFIG_SECURE_SIGNED_APPS_RSA_SCHEME=y
CONFIG_SECURE_SIGNED_ON_UPDATE_NO_SECURE_BOOT=y
# Do NOT sign during the build: CI signs the finished image in a separate step
# (scripts/ci-build-all.sh) with the offline key, so the private key never has to be present
# at compile time and fork/PR builds (no secret) still compile. Leaving this on (its default)
# would force CONFIG_SECURE_BOOT_SIGNING_KEY to exist at build time.
CONFIG_SECURE_BOOT_BUILD_SIGNED_BINARIES=n

# BLE - use NimBLE (lighter than Bluedroid)
CONFIG_BT_ENABLED=y
CONFIG_BT_NIMBLE_ENABLED=y
CONFIG_BT_CONTROLLER_ENABLED=y
CONFIG_BT_NIMBLE_ROLE_CENTRAL=y
CONFIG_BT_NIMBLE_ROLE_PERIPHERAL=n
CONFIG_BT_NIMBLE_ROLE_BROADCASTER=n
CONFIG_BT_NIMBLE_ROLE_OBSERVER=y
CONFIG_BT_NIMBLE_MAX_CONNECTIONS=1
# No NimBLE bond persistence: authentication is app-layer (tesla-ble session keys live in
# our own `tesla_ble` NVS namespace via nvs_storage.cpp), and we never use the BLE Security
# Manager / SMP bonding — so the bond-NVS store is dead weight. Off saves ~2.8 KB flash.
CONFIG_BT_NIMBLE_NVS_PERSIST=n

# BLE MTU - request larger MTU for fewer fragments
CONFIG_BT_NIMBLE_ATT_PREFERRED_MTU=247

# WiFi
CONFIG_ESP_WIFI_STATIC_RX_BUFFER_NUM=10
CONFIG_ESP_WIFI_DYNAMIC_RX_BUFFER_NUM=32
CONFIG_ESP_WIFI_TX_BUFFER_TYPE_DYNAMIC=y

# HTTP Server
CONFIG_HTTPD_MAX_REQ_HDR_LEN=1024
CONFIG_HTTPD_MAX_URI_LEN=512

# LWIP sockets — the default of 10 is too tight: the http server (up to 7 open
# sockets), its listener, mDNS, SNTP and evcc's polling can leave no BSD socket
# free for the OTA client, which then fails with "Failed to create socket". The
# TCP PCB pools already allow 16 (LWIP_MAX_ACTIVE/LISTENING_TCP), so lift the BSD
# socket cap to match and give the background OTA check/download room to connect.
CONFIG_LWIP_MAX_SOCKETS=16

# LWIP TCP windows — the default send/receive windows (~5.7 KB = 4×MSS) force a
# multi-packet response through many round trips, which on a higher-latency WiFi link
# serialises into seconds. Double them (8×MSS) so the gzipped web UI (~13 KB) clears in
# ~1–2 windows instead of three. Modest extra RAM per active socket; heap is tight, so
# we don't go larger (and gzip already shrank the only large response).
CONFIG_LWIP_TCP_SND_BUF_DEFAULT=11520
CONFIG_LWIP_TCP_WND_DEFAULT=11520

# Stack sizes — the NimBLE host task runs our notify-RX callback, which does
# tesla-ble protobuf parsing + mbedtls crypto (ECDH/AES-GCM). The 4K default
# overflows during the session handshake, so give the host task a larger stack.
CONFIG_ESP_MAIN_TASK_STACK_SIZE=8192
CONFIG_BT_NIMBLE_HOST_TASK_STACK_SIZE=8192

# Logging
CONFIG_LOG_DEFAULT_LEVEL_INFO=y

# ── Firmware size reduction (Issue #106 — "Package A", zero-risk / no behaviour change) ──
# These trim flash (and a little rodata) by dropping code paths this firmware never uses.
# None touch the coex-/timing-sensitive NimBLE/WiFi hot paths, so no live re-validation is
# required beyond a normal boot + BLE handshake. The big timing-sensitive lever (`-Os`) and
# the DRAM/feature levers are deliberately kept OUT of this set (their own PRs). Combined ≈21 KB.

# Drop mbedTLS human-readable error-string tables — we only ever log the numeric codes
# (e.g. the MQTTS/OTA TLS handshake reason in /status), never mbedtls_strerror(). ~6 KB.
CONFIG_MBEDTLS_ERROR_STRINGS=n

# No TLS session-ticket resumption: our TLS clients (OTA fetch, MQTTS bridge) open few,
# long-lived connections where resumption buys nothing. ~1.8 KB.
CONFIG_MBEDTLS_CLIENT_SSL_SESSION_TICKETS=n
CONFIG_MBEDTLS_SERVER_SSL_SESSION_TICKETS=n

# No filesystem: certs/keys come from the CA bundle and NVS, never a VFS path. ~1.2 KB.
CONFIG_MBEDTLS_FS_IO=n

# Silent asserts — keep the abort()/reboot on a failed assertion (so a bad state still
# reverts via the rollback gate) but drop the "assert failed: <expr> <file>:<line>" string
# tables. Serial/diag logging is unaffected. ~5 KB.
CONFIG_COMPILER_OPTIMIZATION_ASSERTIONS_SILENT=y

# No WPA3-OWE (Opportunistic Wireless Encryption / open-enhanced) STA support — we join a
# WPA2-PSK home network. ~0.8 KB. (WPA3-SAE is a separate, heavier lever left for later.)
CONFIG_ESP_WIFI_ENABLE_WPA3_OWE_STA=n

# ── Firmware size reduction (Issue #106 — "Package B", the -Os lever) ──
# Build for size (-Os) instead of the ESP-IDF default -Og. Measured on esp32s3 (IDF v5.5.4):
# −133 KB flash (.text −102 KB, .rodata −22 KB) AND −8.5 KB contiguous DIRAM — the latter is the
# real win, since the binding constraint on this device is the largest *contiguous* free block,
# not total heap. IRAM unchanged (residency is section placement, not opt level).
# TIMING-SENSITIVE: -Os changes inlining on the WiFi/BLE coexistence hot paths, so this MUST be
# live-validated (boot + full BLE handshake + sustained run, watching for NEW reboots / RX desync)
# before relying on it — hence its own PR, separate from Package A, so any regression bisects here.
CONFIG_COMPILER_OPTIMIZATION_SIZE=y

# C++ exceptions needed by tesla-ble
CONFIG_COMPILER_CXX_EXCEPTIONS=y

# PSRAM (if available on your board)
# CONFIG_SPIRAM=y
# CONFIG_SPIRAM_MODE_OCT=y
