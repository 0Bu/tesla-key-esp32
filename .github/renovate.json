{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "customManagers": [
    {
      "customType": "regex",
      "description": "Bump the yoziru/tesla-ble git dependency pinned in idf_component.yml",
      "managerFilePatterns": ["/^main/idf_component\\.yml$/"],
      "matchStrings": [
        "git:\\s*\"https://github\\.com/yoziru/tesla-ble\\.git\"\\s+version:\\s*\"(?<currentValue>v[0-9]+\\.[0-9]+\\.[0-9]+)\""
      ],
      "datasourceTemplate": "github-tags",
      "depNameTemplate": "yoziru/tesla-ble"
    },
    {
      "customType": "regex",
      "description": "Bump the ESP-IDF version used by the CI build action",
      "managerFilePatterns": ["/^\\.github/workflows/build\\.yml$/"],
      "matchStrings": [
        "esp_idf_version:\\s*(?<currentValue>v[0-9]+\\.[0-9]+(\\.[0-9]+)?)"
      ],
      "datasourceTemplate": "github-tags",
      "depNameTemplate": "espressif/esp-idf"
    },
    {
      "customType": "regex",
      "description": "Bump the esp-web-tools version pinned in the browser installer",
      "managerFilePatterns": ["/^docs/index\\.html$/"],
      "matchStrings": [
        "esp-web-tools@(?<currentValue>[0-9]+(\\.[0-9]+){0,2})/"
      ],
      "datasourceTemplate": "npm",
      "depNameTemplate": "esp-web-tools"
    }
  ]
}
